{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lattice",
  "version": "0.1.0",
  "identifier": "dev.danieldevelopes.lattice",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "lattice",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
